# Copy this to .env and fill in your values.

# ESV Bible API key (free at https://api.esv.org)
ESV_API_KEY=your_esv_api_key_here

# LLM provider: "mlx" (local Apple Silicon) or "claude" (Anthropic API)
BIBLE_LLM_PROVIDER=mlx

# MLX: path to a model on Hugging Face or a local path
# Download with: python -m mlx_lm.convert --hf-path mistralai/Mistral-7B-Instruct-v0.3 -q
MLX_MODEL_PATH=mlx-community/Mistral-7B-Instruct-v0.3-4bit

# Claude provider (only needed if BIBLE_LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
